{
  "problemMatcher": [
    {
      "owner": "ava",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^\\s+✘ \\[fail\\]:\\s+(.+?)\\s+(Error thrown in test|.+\\.json:.+)$",
          "message": 1,
          "code": 2
        },
        {
          "regexp": "^\\s+tests/(.+\\.js):(\\d+)$",
          "file": 1,
          "line": 2
        }
      ]
    },
    {
      "owner": "ava-error",
      "severity": "error",
      "pattern": [
        {
          "regexp": "Failed to read JSON for .+: .+/work/is-a-dev/is-a-dev/(domains/.+\\.json)",
          "file": 1,
          "message": 0
        }
      ]
    }
  ]
}
