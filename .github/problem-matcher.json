{
  "problemMatcher": [
    {
      "owner": "ava",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^\\s+✘ \\[fail\\]:\\s+(.+?)\\s+(.+)$",
          "message": 1,
          "code": 2
        },
        {
          "regexp": "^\\s+(.+)$",
          "line": 1,
          "loop": true
        }
      ]
    },
    {
      "owner": "ava-syntax-error",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^\\s+SyntaxError:\\s+(.+?):\\s+(.+)$",
          "file": 1,
          "message": 2
        }
      ]
    }
  ]
}
