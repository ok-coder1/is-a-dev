{
  "problemMatcher": [
    {
      "owner": "ava",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^\\s+✘ \\[fail\\]:\\s+(.+?)\\s+(Error thrown in test|.+\\.json:.+)$",
          "message": 1,
          "code": 2
        }
      ]
    },
    {
      "owner": "ava-location",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^\\s+tests/(.+\\.js):(\\d+)$",
          "file": 1,
          "line": 2
        }
      ]
    },
    {
      "owner": "ava-error",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^\\s+Error:\\s+(.+)$",
          "message": 1
        }
      ]
    }
  ]
}
