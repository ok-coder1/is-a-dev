{
  "problemMatcher": [
    {
      "owner": "ava",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^\\s+✘ \\[fail\\]:\\s+(.+)$",
          "message": 1
        },
        {
          "regexp": "^\\s*$"
        },
        {
          "regexp": "^\\s+(.+)$",
          "message": 1
        },
        {
          "regexp": "^\\s+tests\\/(.+\\.js):(\\d+)$",
          "file": 1,
          "line": 2
        }
      ]
    }
  ]
}
