{
  "problemMatcher": [
    {
      "owner": "ava-fail",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^\\s+✘ \\[fail\\]:\\s+(.+)$",
          "message": 1
        }
      ]
    },
    {
      "owner": "ava-file-location",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^\\s+tests\\/(.+\\.js):(\\d+)$",
          "file": 1,
          "line": 2
        }
      ]
    },
    {
      "owner": "ava-error-details",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^\\s+(Error|SyntaxError):\\s+(.+)$",
          "message": 2
        }
      ]
    },
    {
      "owner": "ava-syntax-error",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^\\s+SyntaxError:\\s+(.+?):\\s+(.+)$",
          "file": 1,
          "message": 2
        }
      ]
    },
    {
      "owner": "ava-assertion",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^\\s+(.+)$",
          "message": 1
        }
      ]
    }
  ]
}
