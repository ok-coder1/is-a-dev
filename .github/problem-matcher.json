{
  "problemMatcher": [
    {
      "owner": "ava-tests",
      "pattern": [
        {
          "regexp": "─ (.*) ─$",
          "title": 1
        },
        {
          "regexp": "^\\s+([^(]+):(\\d+):(\\d+)",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": "error",
          "code": 5,
          "message": 6,
          "loop": true
        }
      ]
    }
  ]
}
