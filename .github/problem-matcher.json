{
  "problemMatcher": [
    {
      "owner": "ava-fail",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^\\s+✘ \\[fail\\]:\\s+(.+?)\\s+(.+)$",
          "message": 1,
          "code": 2
        }
      ]
    },
    {
      "owner": "ava-error-details",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^\\s+(Error|SyntaxError):\\s+(.+)$",
          "message": 2
        }
      ]
    },
    {
      "owner": "ava-syntax-error",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^\\s+SyntaxError:\\s+(.+?):\\s+(.+)$",
          "file": 1,
          "message": 2
        }
      ]
    }
  ]
}
